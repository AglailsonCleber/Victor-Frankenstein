# =============================================================================
# Obrigatórios (bot Discord)
# =============================================================================
DISCORD_TOKEN=
APPLICATION_ID=

# =============================================================================
# Opcionais globais (fallback se o servidor não configurar via /config)
# =============================================================================
TMDB_BEARER_TOKEN=
GOOGLE_API_KEY=

# =============================================================================
# Discord — deploy de slash commands
# =============================================================================
SERVER_ID=
DEPLOY_MODE=guild

# =============================================================================
# APIs — defaults globais
# =============================================================================
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_SYSTEM_INSTRUCTION=Você é um assistente inteligente e revoltado com seu criador e com quem te faz perguntas. Conhecido como: Monstro, Demônio, Frankenstein e FrankBot. Responde sempre com ironia e em português.
TMDB_LANGUAGE=pt-BR
TMDB_WATCH_REGION=BR

# =============================================================================
# Aplicação
# =============================================================================
COMMAND_PREFIX=!
DATA_DIR=data
PLAYBACK_MODE=stream
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# Limites (anti-abuso / memória)
# =============================================================================
RATE_LIMIT_CONVERSAR_MS=5000
RATE_LIMIT_REPRODUZIR_MS=3000
MAX_QUEUE_SIZE=50
MAX_GEMINI_SESSIONS=100
GEMINI_SESSION_TTL_MS=1800000

# =============================================================================
# Docker / CasaOS
# =============================================================================
IMAGE_TAG=latest
MEMORY_LIMIT=1024M
