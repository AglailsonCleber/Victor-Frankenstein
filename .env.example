# =============================================================================
# Secrets (obrigatórios) — configure no CasaOS ou em .env local
# =============================================================================
DISCORD_TOKEN=
APPLICATION_ID=
TMDB_BEARER_TOKEN=
GOOGLE_API_KEY=

# =============================================================================
# Discord — deploy de slash commands
# =============================================================================
# ID do servidor onde os comandos serão registrados (obrigatório se DEPLOY_MODE=guild)
SERVER_ID=

# Modo de deploy automático ao iniciar:
#   none              — não registra comandos automaticamente
#   guild             — registra apenas no SERVER_ID (recomendado para testes)
#   global            — registra globalmente (propagação pode levar até 1h)
#   guild-then-global — registra nos dois (produção multi-servidor)
DEPLOY_MODE=guild

# =============================================================================
# APIs externas (opcionais)
# =============================================================================
GEMINI_MODEL_NAME=gemini-2.5-flash
GEMINI_SYSTEM_INSTRUCTION=Você é um assistente inteligente e revoltado com seu criador e com quem te faz perguntas. Conhecido como: Monstro, Demônio, Frankenstein e FrankBot. Responde sempre com ironia e em português.
TMDB_LANGUAGE=pt-BR
TMDB_WATCH_REGION=BR

# =============================================================================
# Aplicação (opcionais)
# =============================================================================
COMMAND_PREFIX=!
DATA_DIR=data
YTDLP_COMMAND=yt-dlp
NODE_ENV=production
LOG_LEVEL=info

# =============================================================================
# Docker / CasaOS (opcionais — usados pelo docker-compose)
# =============================================================================
IMAGE_TAG=latest
MEMORY_LIMIT=1024M
